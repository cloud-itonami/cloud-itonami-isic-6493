{:paths ["src"]
 ;; langgraph-clj brings langchain-clj transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the com-junkawasaki org of this workspace. This repo is standalone
 ;; (forkable outside the workspace); the :local/root paths only resolve
 ;; inside the monorepo checkout — a standalone fork should override them
 ;; with git coordinates.
 :deps {io.github.com-junkawasaki/langgraph-clj
        {:local/root "../../kotoba-lang/langgraph"}
        ;; Real capability libraries this actor depends on as LIVE CODE
        ;; (not just a docstring citation) -- the first cloud-itonami-isic-*
        ;; actor in this fleet to do so, per explicit owner request. See
        ;; docs/adr/0003-real-banking-swift-ekyc-integration.md.
        io.github.kotoba-lang/swift   {:local/root "../../kotoba-lang/swift"}
        io.github.kotoba-lang/banking {:local/root "../../kotoba-lang/banking"}
        io.github.kotoba-lang/ekyc    {:local/root "../../kotoba-lang/ekyc"}
        ;; `factoring.store`'s DatomicStore uses `langchain-store.core`'s
        ;; shared EDN-blob codec (`ls/enc`/`ls/dec*`) instead of hand-
        ;; rolling it -- the same dep `cloud-itonami-isic-3314` pins.
        io.github.kotoba-lang/langchain-store
        {:local/root "../../kotoba-lang/langchain-store"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain-clj to local checkout
  :dev {:override-deps
        {io.github.com-junkawasaki/langchain-clj
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "factoring.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; PRIMARY gate: the portable .cljc suite under a real ClojureScript
  ;; host (runtime priority: cljs first, JVM compat) --
  ;; `factoring.portable-cljs-test-runner`'s own docstring.
  ;;   clojure -Sdeps '{:paths ["src" "test"]}' -M:dev:cljs \
  ;;     -m cljs.main --target node -m factoring.portable-cljs-test-runner
  :cljs {:extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
