{;; This dir's own routes.cljc/kv_store.cljs/worker.cljs.
 :paths ["."]
 ;; :local/root on the repo root brings in ITS OWN `:paths ["src"]`
 ;; (the core factoring.* actor code, unchanged) the idiomatic tools.deps
 ;; way -- routes.cljc is a thin HTTP wrapper around it, never a
 ;; reimplementation, see routes.cljc's own docstring.
 :deps {cloud-itonami/isic-6493 {:local/root ".."}
        io.github.com-junkawasaki/langgraph-clj
        {:local/root "../../../com-junkawasaki/langgraph-clj"}}
 :aliases
 {:dev {:override-deps
        {io.github.com-junkawasaki/langchain-clj
         {:local/root "../../../com-junkawasaki/langchain-clj"}}}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "." "test"
                     "--fail-level" "error"]}
  ;; shadow-cljs (the cljs -> Cloudflare Worker ESM build) reads deps from
  ;; THIS deps.edn's :shadow alias, same idiom as cloud-murakumo-fleet's.
  :shadow {:extra-deps {thheller/shadow-cljs {:mvn/version "2.28.20"}}}}}
